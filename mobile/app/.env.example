# Backend API base URL (required for login, auth, profile).
# With Docker (./start.sh): auth-service is on port 3001, business-service on 3002.
# Use your Mac's LAN IP so the simulator/device can reach the host (e.g. ipconfig getifaddr en0).
# Do NOT use port 3000 — nothing listens there in the Docker setup.
BASE_URL=http://YOUR_MAC_IP:3001

# Optional: extra URLs tried when BASE_URL fails (e.g. inspector APIs live on business-service).
# With Docker, add the business-service URL so /api/inspector/* and profile work after login.
ALT_BASE_URLS=http://YOUR_MAC_IP:3002

# Optional: session idle timeout. Default is 90 days so inspectors stay logged in while in the field.
# SESSION_TTL_DAYS=90
# Or use minutes: SESSION_TTL_MINUTES=129600
