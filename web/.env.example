# Example frontend environment variables for local development
# Backend origin (fallback when proxy fails). Must match how you run the backend:
#   Docker (./start.sh): auth on 3001 -> VITE_BACKEND_ORIGIN=http://localhost:3001, VITE_USE_MICROSERVICES=true
#   Unified (npm run dev in backend/): single API on 3000 -> VITE_BACKEND_ORIGIN=http://localhost:3000, VITE_USE_MICROSERVICES=false
VITE_BACKEND_ORIGIN=http://localhost:3001
# Optional: front-end LLM selection (not recommended; prefer server-side enforcement)
# VITE_LLM=claude-sonnet-4.5

# Cloudflare Turnstile CAPTCHA (IAS-2: Rate + CAPTCHA)
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# For development/testing, you can use: 1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
