# ==========================================
# Capstone Project - Environment Variables Example
# ==========================================
# Copy this file to .env and fill in your actual values

# === Database (IAS-3.7: auth + least-privilege app user) ===
# Root user (admin only; do not use in app). Change in production.
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=devrootpass
# App user (least privilege: readWrite on capstone_project only). Change in production.
MONGO_APP_USER=capstone_app
MONGO_APP_PASSWORD=devapppass
# Connection string: use app user. For Docker (local MongoDB), services use host "mongodb"; for local scripts use localhost.
# For MongoDB Atlas (encryption at rest + TLS): set MONGO_URI to your Atlas URI and run with docker-compose.atlas.yml (see docs/deployment/atlas.md).
MONGO_URI=mongodb://capstone_app:devapppass@localhost:27017/capstone_project?authSource=admin
# Backup encryption (IAS-3.4). Set in production so backups are encrypted (AES-256). deploy/restore.sh needs this for .enc files.
# BACKUP_ENCRYPTION_PASSWORD=

# === Service Ports ===
AUTH_SERVICE_PORT=3001
BUSINESS_SERVICE_PORT=3002
ADMIN_SERVICE_PORT=3003
AUDIT_SERVICE_PORT=3004

# === Service URLs (for inter-service communication) ===
AUTH_SERVICE_URL=http://localhost:3001
BUSINESS_SERVICE_URL=http://localhost:3002
ADMIN_SERVICE_URL=http://localhost:3003
AUDIT_SERVICE_URL=http://localhost:3004
# Auth-service uses ADMIN_SERVICE_URL to create security incidents (e.g. staff/admin forgot-password).
# Audit-service uses ADMIN_SERVICE_URL to create tamper incidents when hash mismatch is detected (e.g. Docker).
# For local dev (no Docker): set ADMIN_SERVICE_URL=http://localhost:3003 and run both auth and admin so incidents are created.
# Optional: ADMIN_SERVICE_INTERNAL_API_KEY for server-to-server auth when calling POST /api/admin/tamper/incidents (auth-service, audit-service).

# === Blockchain Configuration ===
GANACHE_RPC_URL=http://127.0.0.1:7545
# Must match Ganache first account (mnemonic "test test test test test test test test test test test junk")
DEPLOYER_PRIVATE_KEY=  # Ganache first account key — run docker-compose up to auto-populate
ACCESS_CONTROL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
USER_REGISTRY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DOCUMENT_STORAGE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
AUDIT_LOG_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
AUDIT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# === IPFS Configuration ===
IPFS_PROVIDER=local
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs/

# === Email Configuration (signup/login verification emails) ===
# Set EMAIL_API_KEY to receive real verification emails in ALL modes (default, --dev, --demo-ui, --demo).
# Leave as placeholder or unset to use mock (code shown in logs and on screen only; no email sent).
# Provider: resend | sendgrid | mailgun | postmark
EMAIL_API_PROVIDER=resend
EMAIL_API_KEY=your-email-api-key-here
# Optional: EMAIL_API_URL (Resend default: https://api.resend.com)
# Sender: use a verified address in your provider. No domain? With Resend use: onboarding@resend.dev (no verification needed).
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
# Optional: In dev, send all emails to this address (e.g. your Resend account email) so Resend allows delivery when using onboarding@resend.dev
# EMAIL_DEV_REDIRECT_TO=you@example.com

# === Security ===
JWT_SECRET=your-strong-jwt-secret-here-change-in-production
# Field-level encryption key for MongoDB data-at-rest (AES-256-GCM). Required for all services.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=change-me-generate-a-64-char-hex-string
# Service-to-service auth (X-API-Key header); required for write endpoints in production
AUDIT_SERVICE_API_KEY=your-audit-service-api-key-here
# CAPTCHA (IAS-2: Rate + CAPTCHA). When set, login/start and signup/start require a valid Turnstile token.
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# For development/testing, you can use: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# Frontend (web): set in web/.env.local so Vite exposes it: VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# File upload virus scanning (IAS-2: optional). When set, uploads are scanned before acceptance.
# With Docker: use CLAMAV_HOST=clamav and ensure clamav service is running (port 3310).
# CLAMAV_HOST=
# CLAMAV_PORT=3310

# === CORS ===
CORS_ORIGIN=http://localhost:5173

# === Frontend (demo/production build) ===
# Auth service URL for production build (./start.sh --demo). Baked in at build time; default http://localhost:3001 if unset.
# VITE_BACKEND_ORIGIN=http://localhost:3001

# === Google OAuth (Optional) ===
GOOGLE_CLIENT_ID=your-google-web-client-id
GOOGLE_SERVER_CLIENT_ID=your-google-web-client-id

# === Google Generative AI (Gemini) ===
# Required for AI-powered Line of Business recommendation feature.
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: model for LOB classification and help tips (default: gemini-2.5-flash).
# If you get 429 quota exceeded, try a model that shows quota on https://ai.dev/rate-limit (e.g. gemini-2.0-flash or gemini-1.5-flash-8b).
# GEMINI_LOB_MODEL=gemini-2.5-flash

# === LOB Trained Model Service (Optional) ===
# If set, business-service will call this Python service for LOB predictions
# before falling back to Gemini. Run ai/service/predict_app.py to start it.
# LOB_MODEL_SERVICE_URL=http://localhost:5050
# Shared secret for model admin endpoints (/train and /evaluate).
# Required when business-service triggers retraining/evaluation via admin routes.
# LOB_MODEL_ADMIN_TOKEN=change-me-strong-random-token


# === Seeding (Docker / Development) ===
# Set to true to seed form definitions on admin-service startup (when DB is empty)
SEED_FORM_DEFINITIONS=true
# Set to true to seed dev users/roles on auth-service startup
SEED_DEV=true
SEED_TEMP_PASSWORD=TempPass123!

# Development: set to true to disable login/signup rate limits (e.g. when testing many Mailinator accounts)
# DISABLE_RATE_LIMIT=true

# === Development Emergency Fixes ===
# Emergency: Disable email notifications in development to prevent spam
# Set to true to stop all email notifications in development mode
DISABLE_EMAIL_NOTIFICATIONS=true

# Emergency: Disable tamper incident creation in development
# Set to true to prevent creating tamper incidents for blockchain connectivity issues
DISABLE_TAMPER_INCIDENTS=true

# Emergency: Audit verification settings for development
# How many hours back to verify (default: 24)
AUDIT_VERIFY_WINDOW_HOURS=24
# Max audit logs to check per run (default: 200)
AUDIT_VERIFY_MAX=200
# Grace period for new logs before verification in minutes (default: 15)
AUDIT_VERIFY_GRACE_MINUTES=15

# Optional: role emails for dev seed (auth-service). When SEED_DEV=true, these accounts are created/updated on startup.
# Inspector is mobile-app only; use DEV_EMAIL_INSPECTOR for the inspector account (e.g. inspector@example.com).
# DEV_EMAIL_OFFICER=39dfaab3-6daf-410b-bbea-865f8e878583@mailslurp.biz
# DEV_EMAIL_MANAGER=afb90db7-5360-4783-a444-925b22abea70@mailslurp.biz
# DEV_EMAIL_ADMIN=1a7f9616-9643-4598-af65-3b7108e740aa@mailslurp.biz
# DEV_EMAIL_ADMIN2=d7d29cd6-ccf6-4866-b7d1-bdc26dc2e89c@mailslurp.biz
# DEV_EMAIL_ADMIN3=67d7d200-da90-4dcf-8200-a513f5f19990@mailslurp.biz
# DEV_EMAIL_INSPECTOR=inspector@example.com
# DEV_EMAIL_CSO=cso@example.com

# === Docker Internal URLs ===
# These are used automatically by Docker Compose - don't change unless needed.
# Auth-service receives ADMIN_SERVICE_URL from DOCKER_ADMIN_SERVICE_URL so it can create security incidents (staff/admin forgot-password) on admin-service.
DOCKER_AUTH_SERVICE_URL=http://auth-service:3001
DOCKER_BUSINESS_SERVICE_URL=http://business-service:3002
DOCKER_ADMIN_SERVICE_URL=http://admin-service:3003
DOCKER_AUDIT_SERVICE_URL=http://audit-service:3004
DOCKER_IPFS_API_URL=http://ipfs:5001
DOCKER_IPFS_GATEWAY_URL=http://ipfs:8080/ipfs/
